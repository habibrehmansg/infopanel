<Window
    x:Class="InfoPanel.Views.Windows.ProcessPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Select running program"
    Width="400"
    Height="450"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,8"
            Text="Select a running process to use as the trigger app:"
            TextWrapping="Wrap" />
        <ListView
            x:Name="ProcessListView"
            Grid.Row="1"
            Margin="0,0,0,10"
            SelectionMode="Single"
            MouseDoubleClick="ProcessListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding ProcessName}" Header="Process name" Width="180" />
                    <GridViewColumn DisplayMemberBinding="{Binding Id}" Header="PID" Width="60" />
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button
                Margin="0,0,8,0"
                Appearance="Secondary"
                Click="Refresh_Click"
                Content="Refresh" />
            <ui:Button
                Margin="0,0,8,0"
                Appearance="Secondary"
                Click="Cancel_Click"
                Content="Cancel" />
            <ui:Button
                x:Name="OkButton"
                Appearance="Primary"
                Click="Ok_Click"
                Content="OK"
                IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
