<UserControl
    x:Class="InfoPanel.Views.Components.PluginDetailControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:InfoPanel.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="clr-namespace:InfoPanel.Views.Components"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:InfoPanel.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:PluginDetailViewModel}"
    Width="650"
    MinHeight="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:DownloadCountConverter x:Key="DownloadCountConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Loading -->
        <ui:ProgressRing
            Width="40"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsIndeterminate="True"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Content -->
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!-- Header: Icon + Info (left) + Actions (right) -->
            <DockPanel Margin="0,0,0,16">
                <!-- Actions: right column, stacked vertically -->
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- Install / Update button -->
                    <ui:Button
                        x:Name="DownloadButton"
                        Width="120"
                        Appearance="Primary"
                        Click="Download_Click"
                        IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBooleanConverter}}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Content" Value="Install" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                        <Setter Property="Content" Value="Please wait..." />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsInstalled}" Value="True" />
                                            <Condition Binding="{Binding IsUpdateAvailable}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                        <Setter Property="Content" Value="Update" />
                                        <Setter Property="Appearance" Value="Caution" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <!-- Uninstall button (only when installed and no update) -->
                    <ui:Button
                        Width="120"
                        Appearance="Danger"
                        Click="Uninstall_Click"
                        Content="Uninstall"
                        IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBooleanConverter}}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsInstalled}" Value="True" />
                                            <Condition Binding="{Binding IsUpdateAvailable}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:HyperlinkButton
                        Margin="0,4,0,0"
                        HorizontalAlignment="Center"
                        Content="GitHub"
                        NavigateUri="{Binding SourceUrl}">
                        <ui:HyperlinkButton.Style>
                            <Style TargetType="ui:HyperlinkButton" BasedOn="{StaticResource {x:Type ui:HyperlinkButton}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SourceUrl}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:HyperlinkButton.Style>
                    </ui:HyperlinkButton>
                </StackPanel>

                <!-- Icon + Info: left column -->
                <Image
                    Width="64"
                    Height="64"
                    Margin="0,0,16,0"
                    DockPanel.Dock="Left"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    Source="{Binding Icon}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,2"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Author}" />
                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                        <Border
                            Padding="8,2"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="4">
                            <TextBlock
                                FontSize="11"
                                Text="{Binding Category}" />
                        </Border>
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{Binding LatestVersion, StringFormat=v{0}}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- Stats + Your Rating -->
            <DockPanel Margin="0,0,0,16">
                <!-- Your Rating: right-aligned -->
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Your Rating" />
                    <ui:Button Appearance="Transparent" Click="Rate1_Click" Padding="2">
                        <ui:SymbolIcon FontSize="18" Symbol="Star20" x:Name="Star1" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Click="Rate2_Click" Padding="2">
                        <ui:SymbolIcon FontSize="18" Symbol="Star20" x:Name="Star2" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Click="Rate3_Click" Padding="2">
                        <ui:SymbolIcon FontSize="18" Symbol="Star20" x:Name="Star3" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Click="Rate4_Click" Padding="2">
                        <ui:SymbolIcon FontSize="18" Symbol="Star20" x:Name="Star4" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Click="Rate5_Click" Padding="2">
                        <ui:SymbolIcon FontSize="18" Symbol="Star20" x:Name="Star5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </ui:Button>
                </StackPanel>

                <!-- Stats: left -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon
                        FontSize="16"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Symbol="ArrowDownload20" />
                    <TextBlock
                        Margin="4,0,20,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding Downloads, Converter={StaticResource DownloadCountConverter}}" />
                    <components:StarRatingDisplay
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Rating="{Binding AverageRating}" />
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding AverageRating, StringFormat={}{0:0.#}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding RatingCount, StringFormat=({0:0} ratings)}" />
                </StackPanel>
            </DockPanel>

            <!-- Error -->
            <TextBlock
                Margin="0,0,0,12"
                FontSize="12"
                Foreground="#F44336"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Description -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="13"
                FontWeight="Medium"
                Text="Description" />
            <TextBlock
                Margin="0,0,0,16"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding Description}"
                TextWrapping="Wrap" />

            <!-- Changelog -->
            <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                <TextBlock
                    FontSize="13"
                    FontWeight="Medium"
                    Text="What's New" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Medium"
                    Text="{Binding LatestReleaseVersion, StringFormat=v{0}}" />
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="{Binding LatestReleaseDate, Converter={StaticResource UtcToLocalTimeConverter}}" />
            </StackPanel>
            <ItemsControl
                Margin="0,0,0,16"
                ItemsSource="{Binding ChangelogItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="0,2,0,2">
                            <TextBlock
                                Margin="0,0,6,0"
                                DockPanel.Dock="Left"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="&#x2022;" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding}"
                                TextWrapping="Wrap" />
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Previous Releases -->
            <TextBlock
                Margin="0,0,0,4"
                FontSize="13"
                FontWeight="Medium"
                Text="Previous Releases" />
            <ItemsControl ItemsSource="{Binding Releases}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:ReleaseViewModel}">
                        <StackPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Text="{Binding Version, StringFormat=v{0}}" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Text="{Binding PublishedAt, Converter={StaticResource UtcToLocalTimeConverter}}" />
                            </StackPanel>
                            <ItemsControl
                                Margin="12,4,0,0"
                                ItemsSource="{Binding ChangelogItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,1,0,1">
                                            <TextBlock
                                                Margin="0,0,6,0"
                                                DockPanel.Dock="Left"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="&#x2022;" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding}"
                                                TextWrapping="Wrap" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
