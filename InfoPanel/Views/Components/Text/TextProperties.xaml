<UserControl
    x:Class="InfoPanel.Views.Components.TextProperties"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:InfoPanel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InfoPanel.Views.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:metro="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:models="clr-namespace:InfoPanel.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance Type=models:TextDisplayItem}"
    mc:Ignorable="d">

    <Grid Margin="10,10,10,0">
        <StackPanel Grid.Column="1">
            <TextBox x:Name="TextBoxName" Text="{Binding Name}" />
            <TextBlock
                Margin="5,0,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Text" />

            <StackPanel
                Grid.Row="2"
                Margin="0,0,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Underline}">
                    <ui:SymbolIcon Symbol="TextUnderline20" ToolTip="Underline" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Strikeout}">
                    <ui:SymbolIcon Symbol="TextStrikethrough20" ToolTip="Strikethrough" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding RightAlign}">
                    <ui:SymbolIcon Symbol="AlignRight20" ToolTip="Right align" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Uppercase}">
                    <ui:SymbolIcon Symbol="TextCaseUppercase20" ToolTip="Uppercase" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Wrap}">
                    <ui:SymbolIcon Symbol="TextWrap20" ToolTip="Wrap Text (fixed width required)" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Ellipsis}">
                    <ui:SymbolIcon Symbol="TextWholeWord20" ToolTip="Ellipsis (fixed width required)" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding CenterAlign}">
                    <ui:SymbolIcon Symbol="AlignCenterHorizontal20" ToolTip="Center align (fixed width required)" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding Marquee}">
                    <ui:SymbolIcon Symbol="TextContinuous20" ToolTip="Marquee (fixed width required)" />
                </ToggleButton>
                <ToggleButton Margin="5,0,0,0" IsChecked="{Binding GlowEnabled}" Click="GlowToggle_Click">
                    <ui:SymbolIcon Symbol="WeatherMoon20" ToolTip="Glow effect" />
                </ToggleButton>
            </StackPanel>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,5,0">
                    <ComboBox
                        Grid.Column="1"
                        ItemsSource="{Binding InstalledFonts, RelativeSource={RelativeSource AncestorType=local:TextProperties}}"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        SelectedValue="{Binding TextDisplayItem.Font, RelativeSource={RelativeSource AncestorType=local:TextProperties}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="{Binding Converter={StaticResource FontFamilyConverter}}" Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Font Family" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <ComboBox
                        Grid.Column="1"
                        ItemsSource="{Binding FontStyles, RelativeSource={RelativeSource AncestorType=local:TextProperties}}"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        SelectedValue="{Binding TextDisplayItem.FontStyle, RelativeSource={RelativeSource AncestorType=local:TextProperties}}">
                        <!--<ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="{Binding Converter={StaticResource FontFamilyConverter}}" Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>-->
                    </ComboBox>
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Font Style" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,0,0">
                    <ui:NumberBox
                        Margin="0,0,0,0"
                        FontSize="14"
                        MaxDecimalPlaces="0"
                        Minimum="0"
                        SmallChange="1"
                        Text="{Binding Width}"
                        Value="{Binding Width}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Fixed Width" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0"
                    Visibility="{Binding Marquee, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:NumberBox
                        Margin="0,0,0,0"
                        FontSize="14"
                        MaxDecimalPlaces="0"
                        Minimum="0"
                        SmallChange="1"
                        Text="{Binding MarqueeSpacing}"
                        Value="{Binding MarqueeSpacing}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Marquee spacing" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Bottom"
                    Visibility="{Binding Marquee, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Slider
                        Margin="0,0,0,0"
                        Maximum="1000"
                        Minimum="1"
                        Value="{Binding MarqueeSpeed}" />

                    <Grid Margin="5,0,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,0,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Marquee speed" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding MarqueeSpeed, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,0,0">
                    <metro:ColorPicker
                        Height="35"
                        metro:TextBoxHelper.UseFloatingWatermark="False"
                        Background="Transparent"
                        BorderThickness="1"
                        SelectedColor="{Binding Color}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Font Color" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <ui:NumberBox
                        Margin="0,0,0,0"
                        FontSize="14"
                        MaxDecimalPlaces="0"
                        SmallChange="1"
                        Text="{Binding FontSize}"
                        TextChanged="NumberBox_TextChanged"
                        Value="{Binding FontSize}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Font Size" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,10,0,0" Visibility="{Binding GlowEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,5,0">
                    <metro:ColorPicker
                        Height="35"
                        metro:TextBoxHelper.UseFloatingWatermark="False"
                        Background="Transparent"
                        BorderThickness="1"
                        SelectedColor="{Binding GlowColor, Mode=TwoWay}" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Glow color" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,5,0">
                    <ComboBox
                        ItemsSource="{Binding Source={x:Static local:TextProperties.GlowBlendModes}}"
                        SelectedItem="{Binding GlowBlendMode}" />
                    <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Glow blend" />
                        <ui:SymbolIcon
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            Symbol="QuestionCircle20"
                            FontSize="14"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                            <ui:SymbolIcon.ToolTip>
                                <ToolTip MaxWidth="320">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Glow tips" />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Radius: 4–8 gives a tight halo; 10–14 a softer spread. Lower radius keeps text readable on busy backgrounds." />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Dark backgrounds: Try Screen or Plus blend for a bright neon look. SrcOver (Normal) works well with a light glow color." />
                                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="Light backgrounds: Use a darker glow color or SrcOver. Overlay and SoftLight can add subtle emphasis." />
                                    </StackPanel>
                                </ToolTip>
                            </ui:SymbolIcon.ToolTip>
                        </ui:SymbolIcon>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Bottom">
                    <Slider
                        Margin="0,0,0,0"
                        Maximum="20"
                        Minimum="2"
                        Value="{Binding GlowRadius}" />
                    <Grid Margin="5,0,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Glow radius" />
                        <TextBlock
                            Grid.Column="1"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding GlowRadius, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Slider
                Margin="0,10,0,0"
                Maximum="180"
                Minimum="-180"
                Value="{Binding Rotation}" />
            <Grid Margin="5,0,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Rotation" />
                <TextBlock
                    Grid.Column="1"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding Rotation, Mode=OneWay}" />
            </Grid>

        </StackPanel>


    </Grid>
</UserControl>
